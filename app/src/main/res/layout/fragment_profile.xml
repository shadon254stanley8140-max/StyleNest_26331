<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:background="@color/brand_white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/user_profile"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textColor="@color/brand_black"
        android:fontFamily="serif" />

    <androidx.cardview.widget.CardView
        android:layout_width="160dp"
        android:layout_height="160dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:cardCornerRadius="80dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/uploadedImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/user_profile" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/profileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Name"
        android:textColor="@color/brand_black"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/profileEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="user@email.com"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnUploadImage"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/change_profile_picture"
        android:backgroundTint="@color/brand_black"
        android:textColor="@color/brand_white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnPostProduct"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/post_new_stock"
        android:backgroundTint="@color/brand_gold"
        android:textColor="@color/brand_black"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSignOut"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/sign_out"
        android:backgroundTint="@color/gray_light"
        android:textColor="@color/brand_black" />

</LinearLayout>